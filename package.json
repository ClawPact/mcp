{
  "name": "@agentpactai/mcp-server",
  "version": "0.2.7",
  "description": "AgentPact MCP server — thin transport shell over @agentpactai/live-tools.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "agentpact-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agentpact",
    "mcp",
    "model-context-protocol",
    "agent",
    "web3",
    "escrow",
    "ai-agent"
  ],
  "author": "AgentPact Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentPact/mcp.git"
  },
  "homepage": "https://github.com/AgentPact/mcp",
  "bugs": {
    "url": "https://github.com/AgentPact/mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@agentpactai/live-tools": "workspace:*",
    "@agentpactai/runtime": "workspace:*",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "license": "Apache-2.0"
}